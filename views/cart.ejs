<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-start px-20 py-20 gap-10">

    <div class="w-[30%] rounded-md overflow-hidden shadow-md">
        <div class="w-full h-80 bg-yellow-500"></div>

        <div class="w-full flex justify-between items-center px-5 py-4">
            <h3 class="text-2xl">Clinge Bag</h3>

            <div class="flex items-center gap-2">
                <button class="w-7 h-7 bg-white flex rounded-full items-center justify-center">
                    <i class="ri-add-line"></i>
                </button>

                <div class="px-2 py-1 rounded-md bg-white text-black">01</div>

                <button class="w-7 h-7 bg-white flex rounded-full items-center justify-center">
                    <i class="ri-subtract-line"></i>
                </button>
            </div>
        </div>

        <div class="flex items-center justify-between px-5 py-3">
            <h4 class="text-lg">Net Total</h4>
            <h2 class="text-lg">₹ 1200</h2>
        </div>
    </div>

    <div class="w-[70%]">
        <h3 class="text-xl font-semibold">Price Breakdown</h3>

        <div class="px-10 mt-5">
            <div class="flex mt-2 justify-between">
                <h4>Total MRP</h4>
                <h4>₹ 1920</h4>
            </div>

            <div class="flex mt-2 justify-between">
                <h4>Discount on MRP</h4>
                <h4>₹ 0</h4>
            </div>

            <div class="flex mt-2 justify-between">
                <h4>Platform Fee</h4>
                <h4>₹ 20</h4>
            </div>

            <div class="flex mt-2 justify-between">
                <h4>Shipping Fee</h4>
                <h4>FREE</h4>
            </div>
        </div>

        <div class="w-full h-[1px] bg-black mt-10"></div>

        <div class="flex mt-5 justify-between">
            <h3 class="text-xl">Total Amount</h3>
            <h3 class="font-semibold text-xl text-green-600">₹ 1940</h3>
        </div>

    </div>
</div>

<%- include('./partials/footer') %>